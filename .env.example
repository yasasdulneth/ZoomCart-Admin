#############################################
# ZoomCart Backend (shared) - Environment
# Copy this file to `.env` and fill values.
# `.env` is ignored by git (secrets).
#############################################

# Server (Express listens here; this is NOT MongoDB’s port)
NODE_ENV=development
PORT=5000

# MongoDB Atlas
# Paste your Atlas connection string later, e.g.:
# mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/zoomcart?retryWrites=true&w=majority
MONGO_URI=
# Optional fallback when SRV/DNS is blocked on your network.
# Use Atlas "standard connection string" (mongodb://...) here.
MONGO_URI_FALLBACK=

# JWT (admin + client auth can share the same secret)
JWT_SECRET=
# Optional: token lifetime (e.g. 15m, 7d)
JWT_EXPIRES_IN=7d

# Password hashing
# bcryptjs salt rounds (10-12 typical; higher = slower)
BCRYPT_SALT_ROUNDS=10

# CORS (comma-separated list of allowed origins)
# Example: http://localhost:5173,http://localhost:3000
CORS_ORIGINS=

